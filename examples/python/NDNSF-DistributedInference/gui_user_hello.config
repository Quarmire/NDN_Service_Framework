{
  "user": "/NDNSF-DI/Tracer/user",
  "group": "/NDNSF-DI/Tracer/group",
  "controller": "/NDNSF-DI/Tracer/controller",
  "trust_schema": "examples/trust-schema.conf",
  "bootstrap_token": "",
  "permission_wait_ms": 1500,
  "handler_threads": 2,
  "ack_threads": 2,
  "adaptive_admission": false,
  "serve_certificates": true,
  "request": {
    "service_name": "/HELLO",
    "request_strategy": "first-responding",
    "ack_timeout_ms": 1000,
    "timeout_ms": 10000,
    "payload_encoding": "text",
    "payload": "HELLO",
    "request_mode": "normal"
  }
}
