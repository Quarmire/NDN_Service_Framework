{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ndnsf.example/spec108/deployment-profile.schema.json",
  "title": "NDNSF-DI OCI Deployment Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profileId",
    "runId",
    "releaseManifest",
    "runtime",
    "backend",
    "identity",
    "storage",
    "network"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "profileId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._-]+$" },
    "runId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._-]+$" },
    "releaseManifest": { "type": "string", "minLength": 1 },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["docker-compose", "slurm-apptainer"] }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "allowCpuFallback"],
      "properties": {
        "requested": { "enum": ["cpu", "cuda", "onnxruntime-cuda"] },
        "allowCpuFallback": { "type": "boolean" }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "readOnly"],
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "readOnly": { "const": true },
        "expectedIdentity": { "type": "string", "minLength": 1 },
        "roleReferences": {
          "type": "object",
          "additionalProperties": false,
          "required": ["controller", "user", "providers"],
          "properties": {
            "controller": { "type": "string", "pattern": "^/project/[^/]+/ndnsf-di/identities/.+" },
            "user": { "type": "string", "pattern": "^/project/[^/]+/ndnsf-di/identities/.+" },
            "providers": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": { "type": "string", "pattern": "^/project/[^/]+/ndnsf-di/identities/.+" }
            }
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectRoot", "scratchRoot", "evidenceRoot"],
      "properties": {
        "accountRoot": { "type": "string", "minLength": 1 },
        "projectRoot": { "type": "string", "minLength": 1 },
        "scratchRoot": { "type": "string", "minLength": 1 },
        "identityRoot": { "type": "string", "minLength": 1 },
        "imageRoot": { "type": "string", "minLength": 1 },
        "modelRoot": { "type": "string", "minLength": 1 },
        "evidenceRoot": { "type": "string", "minLength": 1 },
        "minimumFreeBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topology", "nfdMode"],
      "properties": {
        "topology": { "enum": ["single-node", "multi-host", "multi-node-allocation"] },
        "nfdMode": { "enum": ["host-scoped", "job-scoped"] },
        "localEndpoint": { "type": "string" },
        "requiredPorts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["protocol", "port"],
            "properties": {
              "protocol": { "enum": ["tcp", "udp"] },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
          }
        },
        "routes": { "type": "array", "items": { "type": "object" } },
        "preflightEvidence": { "type": ["string", "null"] }
      }
    },
    "compose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectName"],
      "properties": {
        "projectName": { "type": "string", "minLength": 1 },
        "composeFile": { "type": "string", "minLength": 1 },
        "nfdSocket": { "type": "string", "minLength": 1 },
        "restartPolicy": { "enum": ["no", "on-failure", "unless-stopped", "always"] }
      }
    },
    "slurm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "partition",
        "wallTime",
        "nodes",
        "tasksPerNode",
        "cpusPerTask",
        "memory",
        "gpu"
      ],
      "properties": {
        "partition": { "type": "string", "minLength": 1 },
        "account": { "type": ["string", "null"] },
        "qos": { "type": ["string", "null"] },
        "wallTime": { "type": "string", "pattern": "^[0-9]+-[0-9]{2}:[0-9]{2}:[0-9]{2}$|^[0-9]{2}:[0-9]{2}:[0-9]{2}$" },
        "nodes": { "type": "integer", "minimum": 1 },
        "tasksPerNode": { "type": "integer", "minimum": 1 },
        "cpusPerTask": { "type": "integer", "minimum": 1 },
        "memory": { "type": "string", "pattern": "^[1-9][0-9]*[KMGTP]?$" },
        "jobName": { "type": "string", "minLength": 1 },
        "gpu": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "count"],
          "properties": {
            "type": { "enum": ["h100_80gb", "rtx_6000", "rtx_5000"] },
            "count": { "type": "integer", "minimum": 0 }
          }
        },
        "networkProbeRequired": { "type": "boolean" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime": {
            "properties": { "kind": { "const": "docker-compose" } },
            "required": ["kind"]
          }
        }
      },
      "then": {
        "required": ["compose"],
        "not": { "required": ["slurm"] },
        "properties": {
          "network": { "properties": { "nfdMode": { "const": "host-scoped" } } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime": {
            "properties": { "kind": { "const": "slurm-apptainer" } },
            "required": ["kind"]
          }
        }
      },
      "then": {
        "required": ["slurm"],
        "not": { "required": ["compose"] },
        "properties": {
          "storage": {
            "properties": {
              "projectRoot": { "pattern": "^/project/[^/]+/ndnsf-di(?:/.*)?$" },
              "scratchRoot": { "pattern": "^/tmp/ndnsf-di-" },
              "evidenceRoot": { "pattern": "^/project/[^/]+/ndnsf-di/evidence(?:/.*)?$" }
            }
          },
          "network": { "properties": { "nfdMode": { "const": "job-scoped" } } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "backend": {
            "properties": { "requested": { "enum": ["cuda", "onnxruntime-cuda"] } },
            "required": ["requested"]
          }
        }
      },
      "then": {
        "if": {
          "properties": {
            "runtime": {
              "properties": { "kind": { "const": "slurm-apptainer" } },
              "required": ["kind"]
            }
          }
        },
        "then": {
          "properties": {
            "slurm": {
              "properties": {
                "gpu": { "properties": { "count": { "minimum": 1 } } }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "network": {
            "properties": { "topology": { "const": "multi-node-allocation" } },
            "required": ["topology"]
          }
        }
      },
      "then": {
        "properties": {
          "network": {
            "required": ["preflightEvidence"],
            "properties": {
              "preflightEvidence": { "type": "string", "minLength": 1 }
            }
          },
          "slurm": {
            "properties": {
              "nodes": { "minimum": 2 },
              "networkProbeRequired": { "const": true }
            }
          }
        }
      }
    }
  ]
}
