#!/usr/bin/env python3
"""NDNSF-DI OCI release and deployment-adapter operator CLI."""

from __future__ import annotations

import argparse
import importlib.util
import json
from pathlib import Path
import sys
from typing import Any


PACKAGE_ROOT = Path(__file__).resolve().parents[1]
LIB_ROOT = PACKAGE_ROOT / "lib"
sys.path.insert(0, str(LIB_ROOT))


def _load(name: str):
    module_name = "ndnsf_container_" + name.replace("/", "_")
    existing = sys.modules.get(module_name)
    if existing is not None:
        return existing
    spec = importlib.util.spec_from_file_location(module_name, LIB_ROOT / f"{name}.py")
    if spec is None or spec.loader is None:
        raise RuntimeError(f"MODULE_UNAVAILABLE:{name}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = module
    spec.loader.exec_module(module)
    return module


profile_impl = _load("profile")
release_impl = _load("release")
evidence_impl = _load("evidence")
compose_impl = _load("adapters/docker_compose")
slurm_impl = _load("adapters/slurm_apptainer")


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--json", action="store_true", dest="json_output")
    parser.add_argument("--verbose", action="store_true")
    commands = parser.add_subparsers(dest="command", required=True)

    profile = commands.add_parser("validate-profile")
    profile.add_argument("--profile", required=True)
    release = commands.add_parser("verify-release")
    release.add_argument("--manifest", required=True)
    evidence = commands.add_parser("verify-evidence")
    evidence.add_argument("--evidence", required=True)

    for name in ("build", "preflight", "install", "materialize", "start", "submit", "status", "wait",
                 "logs", "evidence", "stop", "cancel", "upgrade", "rollback", "cleanup", "render-job"):
        command = commands.add_parser(name)
        command.add_argument("--profile")
        command.add_argument("--job-id")
    return parser


def _success(args: argparse.Namespace, payload: dict[str, Any]) -> int:
    result = {"status": "PASS", **payload}
    if args.json_output:
        print(json.dumps(result, sort_keys=True))
    else:
        print(" ".join(f"{key}={value}" for key, value in result.items()))
    return 0


def _run(args: argparse.Namespace) -> int:
    if args.command == "validate-profile":
        value = profile_impl.load_profile(args.profile)
        return _success(args, {
            "command": args.command, "profileId": value["profileId"], "runId": value["runId"],
            "adapter": value["runtime"]["kind"], "profileDigest": profile_impl.profile_digest(value),
        })
    if args.command == "verify-release":
        value = release_impl.load_release_manifest(args.manifest)
        return _success(args, {"command": args.command, "releaseId": value["releaseId"],
                               "manifestDigest": release_impl.manifest_digest(value)})
    if args.command == "verify-evidence":
        path = Path(args.evidence)
        value = json.loads(path.read_text(encoding="utf-8"))
        evidence_impl.validate_evidence(value)
        return _success(args, {"command": args.command, "runId": value["runId"],
                               "evidenceDigest": evidence_impl.canonical_digest(value)})
    if args.command in {"preflight", "install", "materialize", "start", "status", "logs", "evidence", "stop"} and not args.job_id:
        if not args.profile:
            print(f"PROFILE_REQUIRED:{args.command}", file=sys.stderr)
            return 2
        value = profile_impl.load_profile(args.profile)
        if value["runtime"]["kind"] == "slurm-apptainer":
            adapter = slurm_impl.SlurmApptainerAdapter()
            operation = "materialize" if args.command == "install" else args.command
            if operation == "start": operation = "submit"
            payload = getattr(adapter, operation)(value)
            return _success(args, {"command": args.command, **payload})
        if value["runtime"]["kind"] != "docker-compose": return 7
        adapter = compose_impl.DockerComposeAdapter()
        operation = "materialize" if args.command == "install" else args.command
        payload = getattr(adapter, operation)(value)
        return _success(args, {"command": args.command, **payload})
    if args.command == "submit":
        if not args.profile: print("PROFILE_REQUIRED:submit",file=sys.stderr);return 2
        value=profile_impl.load_profile(args.profile)
        if value["runtime"]["kind"]!="slurm-apptainer": return 7
        return _success(args,{"command":"submit",**slurm_impl.SlurmApptainerAdapter().submit(value)})
    if args.command in {"status","wait","cancel","logs","evidence"} and args.job_id:
        adapter=slurm_impl.SlurmApptainerAdapter(); payload=getattr(adapter,args.command)(args.job_id)
        return _success(args,{"command":args.command,**payload})
    print(f"COMMAND_NOT_IMPLEMENTED:{args.command}", file=sys.stderr)
    return 7


def main(argv: list[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    try:
        return _run(args)
    except profile_impl.ProfileError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    except release_impl.ReleaseError as exc:
        print(str(exc), file=sys.stderr)
        return 4
    except evidence_impl.EvidenceError as exc:
        print(str(exc), file=sys.stderr)
        return 6
    except compose_impl.ComposeAdapterError as exc:
        print(str(exc), file=sys.stderr)
        return 3 if args.command == "preflight" else 5
    except slurm_impl.SlurmAdapterError as exc:
        print(str(exc),file=sys.stderr)
        return 3 if args.command == "preflight" else 5
    except (OSError, json.JSONDecodeError) as exc:
        print(f"INPUT_READ_FAILED:{exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
